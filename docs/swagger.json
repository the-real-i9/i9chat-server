          "500": {
            "content": {
              "application/vnd.msgpack": {
                "schema": {
                  "$ref": "#/components/schemas/appErrors.HTTPError"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "summary": "Signup user - Step 3",
        "tags": [
          "auth"
